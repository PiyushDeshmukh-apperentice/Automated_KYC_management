      "parameters": {
        "jsCode": "let dataToLoop;\n\ntry {\n    // If Consensus ran, we are in Round 2, 3, 4, etc.\n    const consensus = $('Concensus').first().json;\n    const initialFields = $('Edit Fields').first().json;\n\n    dataToLoop = consensus.final_output || {};\n    dataToLoop.target_agent = consensus.target_agent;\n    dataToLoop.audit_trail = consensus.audit_trail;\n    dataToLoop.customer_name = initialFields.customer_name;\n    dataToLoop.customer_id = initialFields.customer_id;\n\n    // ==========================================\n    // THE DATA DIET: Un-nest and strip heavy tokens\n    // ==========================================\n    if (dataToLoop.customer_data) {\n        let cleanData = dataToLoop.customer_data;\n\n        // 1. Flatten if it got buried inside an array during the loops\n        if (cleanData.data && Array.isArray(cleanData.data) && cleanData.data[0]) {\n            cleanData = cleanData.data[0].customer_data || cleanData.data[0];\n        }\n\n        // 2. Token Saver: Delete the raw transactions so Groq doesn't choke\n        if (cleanData.financial?.bank_statement?.transactions) {\n            delete cleanData.financial.bank_statement.transactions;\n        }\n\n        dataToLoop.customer_data = cleanData;\n    }\n\n} catch (e) {\n    // Consensus hasn't run yet. First execution.\n    dataToLoop = $input.first().json;\n}\n\n// Force the 5 loops with the indestructible, clean data\nreturn [1, 2, 3, 4, 5].map(iterationNumber => ({ \n    json: { \n        iteration: iterationNumber,\n        ...dataToLoop \n    } \n}));"
      },
