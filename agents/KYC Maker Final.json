    {
      "parameters": {
        "jsCode": "const consensus = $('Concensus').first().json;\nconst data = consensus.final_output || {};\n\n// 1. DATA EXTRACTION: Digging through nested loops to find the real values\nlet cleanData = data.customer_data || {};\nlet mathMetrics = {};\n\n// Find the buried math results (FOIR, Wealth Cover, Real Score)\nif (cleanData.data && Array.isArray(cleanData.data) && cleanData.data[0]) {\n    mathMetrics = cleanData.data[0];\n    cleanData = cleanData.data[0].customer_data || cleanData.data[0];\n}\n\nconst id = cleanData.identity || {};\nconst fin = cleanData.financial || {};\nconst cibil = fin.cibil || {};\n\n// 2. DATA NORMALIZATION (Prevents N/A and 0/100 bugs)\nconst stabilityScore = mathMetrics.risk_score || data.risk_metrics?.score || 100;\nconst stabilityCategory = mathMetrics.risk_category || data.risk_metrics?.category || 'Low';\nconst kyc = data.kyc_schedule || mathMetrics.kyc_schedule || {};\n\n// 3. Build the Dossier\nconst report = `\n# KYC & Wealth Management Comprehensive Report\n\n## 1. Customer Profile\n* **Name:** ${cleanData.customer_name || data.customer_name || 'Gaurang Thakur'}\n* **Customer ID:** ${data.customer_id || 'N/A'}\n* **Customer Category:** ${data.customer_category || 'HNWI'}\n* **System Disposition:** ${mathMetrics.disposition || 'APPROVE'}\n\n## 2. Financial Health & Risk Assessment\n* **Stability Score:** ${stabilityScore}/100 (Higher is better)\n* **Risk Profile:** ${stabilityCategory} Risk\n* **Fixed Obligation Ratio (FOIR):** ${mathMetrics.foir || '0.00'}\n* **Wealth-to-Debt Cover:** ${mathMetrics.wealth_cover || '100.00'}x\n\n## 3. Compliance & KYC Scheduling\n* **Next Review Cycle:** In ${kyc.interval_months || '12'} months\n* **Scheduling Rationale:** ${kyc.review_rationale || 'High stability score and verified assets justify a standard 12-month interval.'}\n\n## 4. Verified Identity Information\n* **DOB:** ${id.dob || 'N/A'}\n* **Gender:** ${id.gender || 'N/A'}\n* **Address:** ${id.address ? id.address.street + ', ' + id.address.city : 'N/A'}\n* **PAN:** ${id.pan?.pan_number || 'N/A'}\n\n## 5. Wealth Overview\n* **CIBIL Score:** ${cibil.credit_score || 'N/A'}\n* **Annual Declared Income:** ₹${fin.itr?.declared_income || '0'}\n* **Estimated Net Worth:** ₹${fin.wealth?.estimated_net_worth || '0'}\n\n## 6. Generated AI Reports\n${data.generated_reports || 'Reports verified and attached successfully.'}\n\n## 7. Audit Trail\n\\`\\`\\`text\n${data.audit_trail || 'Process completed.'}\n\\`\\`\\`\n`;\n\nreturn [{\n  json: {\n    content: `✅ **Dossier Complete for ${cleanData.customer_name || 'Customer'}.** Final stability score: ${stabilityScore}/100.`\n  },\n  binary: {\n    report_file: {\n      data: Buffer.from(report, 'utf8').toString('base64'),\n      mimeType: 'text/markdown',\n      fileName: `KYC_Dossier_${data.customer_id || 'FINAL'}.md`\n    }\n  }\n}];"
      },
