    {
      "parameters": {
        "jsCode": "// 1. Grab the FAT state that went INTO the agent at the start of the loop\nconst previousState = $('Code in JavaScript').first().json;\nconst executedAgent = previousState.target_agent || \"Retrieval Agent\";\nconst currentTrail = previousState.audit_trail || \"KYC Process Started.\";\n\n// 2. Map to the correct sub-workflow node for extraction\nlet targetNode = \"\";\nif (executedAgent.includes(\"Retrieval\")) targetNode = \"Call Retrieval Agent\";\nelse if (executedAgent.includes(\"Decision\")) targetNode = \"Call Decision Making Agent\";\nelse if (executedAgent.includes(\"RM Banker\")) targetNode = \"Call RM Banker\";\nelse if (executedAgent.includes(\"Template\")) targetNode = \"Call Template Agent\";\nelse if (executedAgent.includes(\"Checker\")) targetNode = \"Call Checker\";\n\nlet winningAgent = \"End\";\nlet winningResponse = {};\n\n// 3. The 5-Vote Round Robin\ntry {\n    const allItems = $(targetNode).all();\n    const items = allItems.slice(-5); // Grab the 5 loop runs\n    \n    const counts = {};\n    let maxCount = 0;\n\n    for (const item of items) {\n        const vote = item.json.call_agent || \"End\";\n        counts[vote] = (counts[vote] || 0) + 1;\n        if (counts[vote] > maxCount) {\n            maxCount = counts[vote];\n            winningAgent = vote;\n        }\n    }\n\n    winningResponse = items.find(i => (i.json.call_agent || \"End\") === winningAgent).json;\n} catch (e) {\n    winningAgent = previousState.call_agent || \"End\";\n    winningResponse = previousState;\n}\n\n// ==========================================\n// 4. THE MASTER STATE MERGE (The Magic Fix)\n// ==========================================\n// We take the old global state and overwrite it with whatever new keys \n// the winning agent produced, but KEEP all the old keys (customer_data, reports, etc.)\nconst masterState = {\n    ...previousState,\n    ...winningResponse\n};\n\n// ==========================================\n// 5. RICH AUDIT TRAIL CONSTRUCTION\n// ==========================================\n// Actually capturing the logic and reasoning, not just the names\nconst actionLog = winningResponse.log_entry || \"Action completed\";\nconst reasoning = winningResponse.decision_reasoning || winningResponse.discrepancy_reason || \"No rationale provided\";\n\nconst newAuditEntry = `[${executedAgent}] -> [Next: ${winningAgent}]\\n   ↳ Action: ${actionLog}\\n   ↳ Rationale: ${reasoning}`;\nconst updatedTrail = currentTrail + `\\n\\n` + newAuditEntry;\n\n// Save the trail and routing back to the Master State\nmasterState.audit_trail = updatedTrail;\nmasterState.target_agent = winningAgent;\n\n// 6. Return the Indestructible Payload to the Loop\nreturn [{\n    json: {\n        final_output: masterState, // The unified God Object containing EVERYTHING\n        target_agent: winningAgent, \n        task_type: masterState.task_type || \"None\",\n        log_entry: actionLog,\n        audit_trail: updatedTrail\n    }\n}];"
      },
